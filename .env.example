# Safe example values only. Copy to apps/api/.env and fill real secrets locally.

NODE_ENV=development
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:4000
TRUST_PROXY=false

DATABASE_URL=postgresql://autoedit:autoedit@localhost:5432/autoedit?schema=public
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
INTEGRATION_ENCRYPTION_SECRET=replace-with-32-byte-minimum-random-secret

AWS_REGION=your-bucket-region
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=your-s3-bucket-name
S3_PRESIGN_TTL=3600

# Optional. Required only when AI_PROVIDER=claude.
ANTHROPIC_API_KEY=

AI_PROVIDER=fallback
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b

WHISPER_URL=http://localhost:9000
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

RENDER_WORK_DIR=C:\autoedit-work
BACKGROUND_MUSIC_PATH=
BACKGROUND_MUSIC_VOLUME=0.1
MAX_UPLOAD_BYTES=5368709120

ANALYSIS_CONCURRENCY=1
ANALYSIS_LOCK_DURATION_MS=900000
RENDER_CONCURRENCY=1
RENDER_TIMEOUT_MS=3600000
MEMORY_THRESHOLD_MB=1536

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_WEBHOOK_SECRET=replace-with-a-webhook-secret

ENABLE_DIARIZATION=false
HUGGINGFACE_TOKEN=
